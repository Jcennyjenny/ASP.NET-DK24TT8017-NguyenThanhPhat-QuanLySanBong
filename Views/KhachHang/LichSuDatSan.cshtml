@model IEnumerable<QuanLySanBong.Models.DatLich>
@{
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-uppercase text-primary fw-bold">Lịch Sử Đặt Sân Của Bạn</h2>
        <a href="/KhachHang/TrangTimSan" class="btn btn-success">➕ Đặt Lịch Sân Mới</a>
    </div>

    <div class="card shadow p-3">
        <table class="table table-hover table-striped text-center align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Mã Đơn</th>
                    <th>Tên Sân</th>
                    <th>Ngày Đá</th>
                    <th>Khung Giờ</th>
                    <th>Tổng Tiền</th>
                    <th>Ngày Đặt Lịch</th>
                    <th>Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-muted p-4">Bạn chưa thực hiện lượt đặt sân nào!</td>
                    </tr>
                }
                @foreach (var don in Model)
                {
                    <tr>
                        <td>#@don.MaDatLich</td>
                        <td class="fw-bold text-success">@don.MaSanNavigation?.TenSan</td>
                        <td>@don.NgayDa.ToString("dd/MM/yyyy")</td>
                        <td class="fw-bold text-dark">@don.GioBatDau.ToString("HH:mm") - @don.GioKetThuc.ToString("HH:mm")</td>
                        <td class="text-danger fw-bold">@don.TongTien?.ToString("N0") VNĐ</td>
                        <td><small class="text-muted">@don.NgayDat?.ToString("dd/MM/yyyy HH:mm")</small></td>
                        <td>
                            @if (don.TrangThai == "Đang chờ")
                            {
                                <span class="badge bg-warning text-dark">Đang chờ duyệt</span>
                            }
                            else if (don.TrangThai == "Đã xác nhận")
                            {
                                <span class="badge bg-success">Thành công</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Đã hủy</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>