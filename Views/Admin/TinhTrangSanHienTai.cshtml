@model IEnumerable<QuanLySanBong.Models.DatLich>
@{
    Layout = "_Layout";
    var cacSan = ViewBag.CacSan as List<QuanLySanBong.Models.SanBong>;
    // Các khung giờ hoạt động cố định của sân bóng trong ngày để phân ca
    var cacKhungGio = new List<string> { "07:30", "09:00", "16:00", "17:30", "19:00", "20:30" };
}

<div class="container mt-4">
    <h2 class="text-center text-uppercase text-dark mb-4">Bảng Theo Dõi Trạng Thái Sân Trực Quan</h2>

    <form method="get" action="/Admin/TinhTrangSanHienTai" class="row g-3 justify-content-center mb-4">
        <div class="col-auto">
            <label class="col-form-label fw-bold">Chọn ngày xem lịch:</label>
        </div>
        <div class="col-auto">
            <input type="date" name="ngayXem" value="@ViewBag.NgayChon" class="form-control" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Xem Trạng Thái</button>
        </div>
    </form>

    <table class="table table-bordered text-center align-middle shadow">
        <thead class="table-dark">
            <tr>
                <th style="width: 20%;">Tên Sân / Cấu Hình</th>
                @foreach (var gio in cacKhungGio)
                {
                    <th>Ca @gio</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var san in cacSan)
            {
                <tr>
                    <td class="fw-bold bg-light">@san.TenSan <br /><span class="badge bg-secondary">Sân @san.LoaiSan người</span></td>

                    @foreach (var gioStr in cacKhungGio)
                    {
                        var gioCheck = TimeOnly.Parse(gioStr); // Chuyển từ TimeSpan.Parse sang TimeOnly.Parse
                        var datLich = Model.FirstOrDefault(d => d.MaSan == san.MaSan &&
                                                           gioCheck >= d.GioBatDau && gioCheck < d.GioKetThuc);

                        if (datLich != null)
                        {
                            <td class="table-danger bg-danger text-white p-3">
                                <div class="fw-bold">@datLich.MaNguoiDungNavigation?.HoTen</div>
                                <small>📞 @datLich.MaNguoiDungNavigation?.SoDienThoai</small>
                                <div class="badge bg-warning text-dark mt-1">@datLich.TrangThai</div>

                                @if (datLich.TrangThai == "Đang chờ")
                                {
                                    <div class="d-flex justify-content-center gap-1 mt-2">
                                        <form action="/Admin/DuyetLich" method="post" style="display:inline;">
                                            <input type="hidden" name="maDatLich" value="@datLich.MaDatLich" />
                                            <button type="submit" class="btn btn-xs btn-light text-success fw-bold p-1" style="font-size: 11px;">Duyệt</button>
                                        </form>
                                        <form action="/Admin/HuyLich" method="post" style="display:inline;">
                                            <input type="hidden" name="maDatLich" value="@datLich.MaDatLich" />
                                            <button type="submit" class="btn btn-xs btn-light text-danger fw-bold p-1" style="font-size: 11px;" onclick="return confirm('Hủy lịch này?')">Hủy</button>
                                        </form>
                                    </div>
                                }
                            </td>
                        }
                        else
                        {
                            <td class="table-success bg-success text-white opacity-75 p-3">
                                <span class="badge bg-light text-success p-2">Trống Lịch</span>
                            </td>
                        }
                    }
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3 text-center">
        <a href="/Admin/DanhSachSan" class="btn btn-outline-dark">👉 Chuyển sang trang Quản lý Sân bóng</a>
    </div>
</div>